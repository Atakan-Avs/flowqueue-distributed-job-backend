APP_NAME=FlowQueue
APP_ENV=development
DEBUG=True

API_V1_PREFIX=/api/v1

POSTGRES_DB=flowqueue_db
POSTGRES_USER=flowqueue_user
POSTGRES_PASSWORD=flowqueue_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

DATABASE_URL=postgresql://flowqueue_user:flowqueue_pass@postgres:5432/flowqueue_db
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

JWT_SECRET_KEY=super-secret-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60